# ============================================================
# PROreport - Variables de entorno (EJEMPLO)
# Copia este archivo a .env y completa con tus valores reales.
# ============================================================

# --- Supabase ---
PROJECT_REF=tu_proyecto_ref_aqui
SUPABASE_URL=https://tu-proyecto-ref.supabase.co

# Publishable key (segura para exponer en cliente Flutter)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Service Role Key (SOLO para scripts/admin - NUNCA en app cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Access Token para Management API (deploy de schemas/RPC)
ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Aplicación ---
CONTRATO_CODIGO=CC-XXXXXXXXXX

# Ruta al CSV oficial
CSV_PATH=LISTADO OFICIAL CC SC-XXXXXXXXXX.xlsx

# --- Storage ---
STORAGE_BUCKET=documentos_hse